# ─── LV.AI Environment Configuration ─────────────────────────────────────────

# Auth Secret (generate: openssl rand -base64 32)
AUTH_SECRET=****

# 9Router (NeXify) — OpenAI-kompatibler Multi-Provider-Gateway
# Zwei Endpunkte (gleicher Key):
#   - LOKAL:   http://127.0.0.1:20128/v1   (gleicher VPS, kein TLS-Overhead)
#   - PUBLIC:  https://ai-router.nexifyai.cloud/v1  (Remote, Vercel, via Cloudflare Tunnel)
# Für Vercel-Production: PUBLIC-URL setzen. Für lokalen Dev: LOKAL-URL.
# Modelle: nexifyai-combo-llm (Default), ds/deepseek-v4-pro, ds/deepseek-v4-flash
OPENAI_API_KEY=****
OPENAI_BASE_URL=http://127.0.0.1:20128/v1

# Postgres (Neon)
POSTGRES_URL=****

# Redis (optional, für Caching und Resumable Streams)
REDIS_URL=****

# Vercel Blob (optional — Datei-Uploads)
# Produktion: Token setzen, um Vercel Blob zu nutzen.
# Entwicklung/ohne Token: Dateien werden lokal nach public/uploads/lv-ai/
# gespeichert und unter /uploads/lv-ai/<name> ausgeliefert.
BLOB_READ_WRITE_TOKEN=

# Mem0 — Cross-Project Memory
MEM0_API_KEY=****
MEM0_USER_ID=****

# LV.AI Passwort-Gate (MVP)
LV_PASSWORD=LV2026!!

# Demo Mode
IS_DEMO=0
